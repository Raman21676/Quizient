<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Night sky background -->
    <item android:drawable="@color/splash_background" />

    <!-- Moon -->
    <item
        android:width="80dp"
        android:height="80dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#FFFDE7" />
        </shape>
    </item>

    <!-- Moon shadow (crescent effect) -->
    <item
        android:width="70dp"
        android:height="70dp"
        android:gravity="center"
        android:left="15dp">
        <shape android:shape="oval">
            <solid android:color="#1A1A2E" />
        </shape>
    </item>

    <!-- Star 1 -->
    <item
        android:width="6dp"
        android:height="6dp"
        android:gravity="top|left"
        android:top="60dp"
        android:left="80dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Star 2 -->
    <item
        android:width="4dp"
        android:height="4dp"
        android:gravity="top|right"
        android:top="100dp"
        android:right="60dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Star 3 -->
    <item
        android:width="5dp"
        android:height="5dp"
        android:gravity="top|left"
        android:top="140dp"
        android:left="120dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Star 4 -->
    <item
        android:width="3dp"
        android:height="3dp"
        android:gravity="top|right"
        android:top="180dp"
        android:right="100dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Star 5 -->
    <item
        android:width="4dp"
        android:height="4dp"
        android:gravity="top|left"
        android:top="220dp"
        android:left="60dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Star 6 -->
    <item
        android:width="6dp"
        android:height="6dp"
        android:gravity="top|right"
        android:top="250dp"
        android:right="80dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Star 7 -->
    <item
        android:width="3dp"
        android:height="3dp"
        android:gravity="top|left"
        android:top="300dp"
        android:left="150dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Star 8 -->
    <item
        android:width="5dp"
        android:height="5dp"
        android:gravity="top|right"
        android:top="320dp"
        android:right="140dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
